<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.toddhoff.tesla-run-due</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>/Users/toddhoff/tesla/scripts/run-due.zsh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/toddhoff/tesla</string>

    <key>StartInterval</key>
    <integer>1800</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/toddhoff/tesla/logs/launchd-run-due.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/toddhoff/tesla/logs/launchd-run-due.err.log</string>
  </dict>
</plist>
